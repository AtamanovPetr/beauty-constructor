generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Site {
  id        String   @id @default(cuid())
  title     String
  phrase    String   @default("")
  skills    String   @default("")
  logo      String   @default("")
  inst      String   @default("")
  phone     String   @default("")
  reviews   String   @default("")
  address   String   @default("")
  gallery   String   @default("")
  html      String
  userId    String
  user      User   @relation(fields: [userId], references: [firebaseUid])
  slug      String   @unique
  published Boolean  @default(false)
  style     String   @default("rose")
  createdAt DateTime @default(now())
  domain String? @unique
  metaTitle       String?
  metaDescription String?
}

model User {
  firebaseUid  String @id // ← теперь первичный ключ
  name         String?
  email        String?
  plan         String @default("FREE")
  sitesLimit   Int    @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  sites        Site[]
}