generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Site {
  id        String   @id @default(cuid())
  title     String
  html      String
  userId    String
  slug      String   @unique
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  style     String   @default("teal")   // ← добавь, если отсутствует
}