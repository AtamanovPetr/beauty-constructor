generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Site {
  id        String  @id @default(cuid())
  title     String
  html      String
  userId    String
  slug      String  @unique
  published Boolean @default(false)
  createdAt DateTime @default(now())
}